#include <iostream>
#include <string>
using namespace std;

// Check if we can turn off all bulbs with given l
bool canTurnOff(string s, int n, int k, int l) {
    int ops = 0;

    for (int i = 0; i < n; ) {
        if (s[i] == '1') {
            ops++;
            if (ops > k) return false;
            i += l;  // skip l bulbs
        } else {
            i++;
        }
    }
    return true;
}

int main() {
    int n, k;
    cin >> n >> k;

    string s;
    cin >> s;

    int left = 1, right = n;
    int ans = n;

    while (left <= right) {
        int mid = (left + right) / 2;

        if (canTurnOff(s, n, k, mid)) {
            ans = mid;
            right = mid - 1;  // try smaller l
        } else {
            left = mid + 1;
        }
    }

    cout << ans << endl;

    return 0;
}
